# Public AgentCash API origin. Set this to the exact custom domain agents call.
BASE_URL=https://ryansproule.com

# AgentCash/x402 payment config.
EVM_PAYEE_ADDRESS=
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Optional MPP support. Set these to advertise MPP alongside x402.
MPP_SECRET_KEY=
MPP_CURRENCY=0x20c000000000000000000000b9537d11c60e8b50

# Optional persistent KV for production replay/nonce hardening.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Contact route pricing.
AGENT_EMAIL_PRICE_USD=0.25
AGENT_MESSAGE_PRICE_USD=1.00

# Resend-backed paid email route.
RESEND_API_KEY=
RESEND_FROM_EMAIL="RFS PAID Agent Mail <agent@mail.ryansproule.com>"
RYAN_EMAIL_TO=

# Telegram-backed paid direct message route.
TELEGRAM_BOT_TOKEN=
RYAN_TELEGRAM_CHAT_ID=
